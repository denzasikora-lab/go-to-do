# Copy this file to `.env` and fill in secrets before running the bot or Compose.

# Required: Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Postgres connection string. When using docker-compose.yml, the hostname is the service name `postgres`.
POSTGRES_DSN=postgres://todobot:todobot@postgres:5432/todobot?sslmode=disable

# Example for Postgres listening on localhost (no Docker):
# POSTGRES_DSN=postgres://todobot:todobot@127.0.0.1:5432/todobot?sslmode=disable
